# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/content_review
DATABASE_SYNC_URL=postgresql+psycopg2://user:password@localhost:5432/content_review

# FRED API
FRED_API_KEY=your_fred_api_key

# SEC EDGAR
SEC_EMAIL=your_email@example.com
SEC_USER_AGENT=YourCompany/1.0

# Alpha Vantage
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# Polygon.io
POLYGON_API_KEY=your_polygon_api_key

# Bureau of Labor Statistics
BLS_API_KEY=your_bls_api_key

# News API
NEWS_API_KEY=your_news_api_key

# NBER
NBER_BASE_URL=https://www.nber.org

# Server
HOST=0.0.0.0
PORT=8000
ENV=development
